{
  "manifest_version": 3,
  "name": "LinkedIn location Collector",
  "version": "1.0",
  "description": "Сохраняет имя и местоположение пользователей LinkedIn в CSV.",
  "permissions": ["storage", "scripting", "activeTab", "downloads"],
  "host_permissions": ["https://www.linkedin.com/search/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/search/*"],
      "js": ["content.js"]
    }
  ]
} 